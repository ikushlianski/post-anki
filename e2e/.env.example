# post-anki e2e local env. Copy to e2e/.env (gitignored) and adjust.
# The e2e stack runs on dedicated ports against a LOCAL Postgres — never Neon.

# Local Postgres (docker-compose.yml maps it to host :5436). LOCAL ONLY.
E2E_DATABASE_URL=postgres://postanki:postanki@localhost:5436/postanki_e2e

# Dedicated ports so the e2e stack never collides with your normal dev (:8030/:3000)
# or other projects.
E2E_API_PORT=8031
E2E_WEB_PORT=3100

# Bearer shared between the e2e web BFF and the e2e API. Any value; must match.
API_SHARED_SECRET=e2e-local-secret

# A dummy key boots the API fine: LLM calls are intercepted by the local mock
# OpenRouter server (playwright.config points OPENROUTER_BASE_URL at it), so no
# real OpenRouter request is ever made during e2e.
OPENROUTER_API_KEY=e2e-unused
CURRICULUM_MODEL=openrouter/openai/gpt-4o-mini
LOG_LEVEL=warn

# Playwright baseURL (the e2e web port).
PROJECT_DEV_SERVER_URL=http://localhost:3100
