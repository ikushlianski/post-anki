# @post-anki/api — copy to apps/api/.env and fill in to run the full loop locally.

# Neon serverless Postgres connection string (shared with the bot).
DATABASE_URL=

# OpenRouter API key — required for the architect + mentor + decide agents.
OPENROUTER_API_KEY=

# Model used by every agent. Override to swap cost/quality.
# gpt-4o-mini: cheapest option that supports structured output + web search
# (tool calling) in a single call. Gemini 2.5 Flash cannot combine the two.
CURRICULUM_MODEL=openrouter/openai/gpt-4o-mini

# Optional bearer secret. If set, every route except /healthz requires
# Authorization: Bearer <this>. Leave blank for open local dev.
API_SHARED_SECRET=

# HTTP port (defaults to 8030).
PORT=8030

# debug | info | warn | error
LOG_LEVEL=info
