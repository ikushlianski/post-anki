# @post-anki/api local dev env.
#
# Two-file setup (both gitignored):
#   .env        committed-shape base: local Postgres + non-secret defaults.
#   .env.local  secrets/overrides (e.g. OPENROUTER_API_KEY). Loaded last, wins.
#
# Prod does NOT use these files — Cloud Run env vars come from GitHub Secrets
# (PROD_DATABASE_URL, PROD_OPENROUTER_API_KEY, ...) via .github/workflows/deploy.yml.

# --- .env ---

# Local dev Postgres (docker compose up -> container post-anki-dev-db on :5437).
# Persistent volume, separate from the ephemeral e2e DB on :5436.
DATABASE_URL=postgres://postanki:postanki@localhost:5437/postanki_dev

# gpt-4o-mini: cheapest option that supports structured output + web search
# (tool calling) in a single call. Gemini 2.5 Flash cannot combine the two.
CURRICULUM_MODEL=openrouter/openai/gpt-4o-mini

# Bearer shared with the web BFF. Must match apps/web/.env (API_SHARED_SECRET).
API_SHARED_SECRET=local-dev-secret

PORT=8030
LOG_LEVEL=info

# --- .env.local ---

# OpenRouter API key — same key for local dev and prod. Paste yours here.
OPENROUTER_API_KEY=

# Langfuse tracing (Cloud EU). Both keys present → Mastra exports agent/LLM
# traces to Langfuse. Leave blank → tracing is gracefully disabled.
# Prod reads these from GitHub Secrets PROD_LANGFUSE_* (see deploy.yml).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
