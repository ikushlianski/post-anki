# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
OWNER_TELEGRAM_CHAT_ID=

# LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/google/gemini-2.5-flash

# DB
# Local dev: point at the docker dev DB (docker compose up -> :5437).
#   DATABASE_URL=postgres://postanki:postanki@localhost:5437/postanki_dev
# Prod: injected by CI from GitHub Secret PROD_DATABASE_URL (Neon), not this file.
DATABASE_URL=

# Runtime
PORT=8080
LOG_LEVEL=info

# API (@post-anki/api) — reuses OPENROUTER_API_KEY + DATABASE_URL above
CURRICULUM_MODEL=openrouter/google/gemini-2.5-flash
API_SHARED_SECRET=
# api process reads PORT (defaults to 8030 if unset)
